# ─── Sanity CMS ───────────────────────────────────────────────
# Get these from sanity.io/manage after creating a project
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=your_read_token   # optional for public data

# ─── WhatsApp ─────────────────────────────────────────────────
# Your WhatsApp Business number with country code, no +
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX

# ─── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mychoice.in
